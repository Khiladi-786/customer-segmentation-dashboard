# ─── LLM (Google Gemini — free tier) ─────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite (no setup needed). Uncomment + set for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/segmentation_db

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns

# ─── FastAPI Backend ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Streamlit ────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ─── Clustering ───────────────────────────────────────────────────────────────
# Number of clusters to test in AutoML (min to max)
CLUSTER_RANGE_MIN=2
CLUSTER_RANGE_MAX=10
DEFAULT_N_CLUSTERS=5
